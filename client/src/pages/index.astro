---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home">
  <section class="hero">
    <div class="container">
      <h1 class="hero__title">Find Your Next <span>Favorite Game</span></h1>
      <p class="hero__subtitle">
        Tell us what you like and we'll recommend games you'll love. Powered by data from thousands
        of titles.
      </p>
      <div class="hero__actions">
        <a href="/recommendations" class="btn btn--primary">Get Recommendations</a>
        <a href="/search" class="btn btn--outline">Search Games</a>
      </div>
    </div>
  </section>
</BaseLayout>
